# WhoCards — single root env file.
#
# All apps/packages read THIS file: the website via Astro's vite.envDir (→ repo root),
# and mobile/drizzle via the `with-env` scripts (dotenv-cli: `dotenv -e ../../.env`).
# Copy to `.env` and fill in. `.env` is gitignored; `.env.example` is committed.
# Per-environment overrides: `.env.prod` etc., selected with `ENV=prod pnpm <script>`.

# --- Database (required) ---
# Postgres / Supabase connection. NOTE: this is currently the PROD database, so local
# dev reads/writes prod data. Point at localhost for an isolated local DB if preferred.
DB_URL=postgres://user:password@host:5432/postgres

# --- Request Cards form (required) ---
# Google Sheet webhook the /contact form posts each card request to.
CONTACTS_SHEET_URL=

# --- Email — AI Check-In lead magnet (optional; Resend) ---
RESEND_API_KEY=
RESEND_FROM_EMAIL=WhoCards <hello@whocards.cc>

# --- Analytics (optional; PostHog, client-exposed via PUBLIC_ prefix) ---
PUBLIC_POSTHOG_KEY=
# api_host: route events through a neutral CNAME → PostHog EU proxy.
# Set to your managed reverse-proxy subdomain (e.g. https://e.whocards.com)
# to avoid browser ad-blockers. Defaults to eu.i.posthog.com (direct EU).
PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com
# ui_host: the PostHog UI origin for the toolbar/survey widgets.
PUBLIC_POSTHOG_UI_HOST=https://eu.posthog.com

# --- Mobile (Expo) ---
# Overrides the API base URL the app calls. Unset → prod (https://whocards.cc) in
# release builds, the LAN host Expo reports in dev.
EXPO_PUBLIC_API_URL=

# --- Answer recording opt-in (optional) ---
# Recording feeds the shared Global progress and is ALWAYS on in production builds.
# In dev it is suppressed so local play doesn't pollute the real Answer record. Set
# to 'true' to opt in while developing. Two vars, same effect (platform env-prefix
# conventions): web → PUBLIC_RECORD_ANSWERS, mobile → EXPO_PUBLIC_RECORD_ANSWERS.
PUBLIC_RECORD_ANSWERS=
EXPO_PUBLIC_RECORD_ANSWERS=
