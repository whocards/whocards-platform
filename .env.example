# WhoCards — single root env file.
#
# All apps/packages read THIS file: the website via Astro's vite.envDir (→ repo root),
# and mobile/drizzle via the `with-env` scripts (dotenv-cli: `dotenv -e ../../.env`).
# Copy to `.env` and fill in. `.env` is gitignored; `.env.example` is committed.
# Per-environment overrides: `.env.prod` etc., selected with `ENV=prod pnpm <script>`.

# --- Database (required) ---
# Postgres / Supabase connection. NOTE: this is currently the PROD database, so local
# dev reads/writes prod data. Point at localhost for an isolated local DB if preferred.
DB_URL=postgres://user:password@host:5432/postgres

# --- Request Cards form (required) ---
# Google Sheet webhook the /contact form posts each card request to.
CONTACTS_SHEET_URL=

# --- Cloudflare Turnstile (required for the /contact form, #81) ---
# Bot protection for the general contact form. PUBLIC_TURNSTILE_SITE_KEY is
# client-exposed (Astro PUBLIC_ prefix) and rendered in the widget; the secret key
# verifies tokens server-side via challenges.cloudflare.com/turnstile/v0/siteverify.
# Both come from the Cloudflare Turnstile dashboard.
PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# --- Email (required; Resend) ---
# All four Resend values below are REQUIRED — the website build fails without them
# so a misconfigured prod deploy fails loudly instead of silently dropping email
# or consent events (2026-07-02: missing webhook secret 500'd every delivery until
# Resend disabled the endpoint).
RESEND_API_KEY=
RESEND_FROM_EMAIL=WhoCards <hello@whocards.cc>
# Resend Segment (Audience) ids for consent sync (#120). Find in Resend → Contacts → Segments.
RESEND_SEGMENT_NEWSLETTER_ID=
RESEND_SEGMENT_APP_WAITLIST_ID=
# Svix signing secret for /api/webhooks/resend (#121), format whsec_... — must match
# the endpoint's signing_secret (Resend → Webhooks → endpoint, or GET /webhooks/{id}).
RESEND_WEBHOOK_SECRET=
# Android tester recruitment. The /android-testers page uses the group + opt-in
# links directly; lifecycle emails use all three values.
ANDROID_TESTER_SIGNUP_URL=https://whocards.cc/android-testers
ANDROID_TESTER_GROUP_URL=https://groups.google.com/a/whocards.cc/g/whocards-testers
ANDROID_TESTER_OPT_IN_URL=https://play.google.com/apps/testing/com.whocards.mobile
ANDROID_TESTER_FEEDBACK_URL=https://whocards.cc/contact
# Single recipient for `EMAIL_TEST_SEND_CONFIRMED=true pnpm email:test-send`.
EMAIL_TEST_RECIPIENT=

# --- Analytics (optional; PostHog, client-exposed via PUBLIC_ prefix) ---
PUBLIC_POSTHOG_KEY=
# api_host: route events through a neutral CNAME → PostHog EU proxy.
# Set to your managed reverse-proxy subdomain (e.g. https://e.whocards.cc)
# to avoid browser ad-blockers. Defaults to eu.i.posthog.com (direct EU).
PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com
# ui_host: the PostHog UI origin for the toolbar/survey widgets.
PUBLIC_POSTHOG_UI_HOST=https://eu.posthog.com
# Mobile (Expo) — same PostHog project, EXPO_PUBLIC_ prefix so Expo inlines it into
# the client bundle. Direct EU ingestion (native apps aren't ad-blocked → no proxy).
EXPO_PUBLIC_POSTHOG_KEY=
EXPO_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com
# Generic debug switch (true/false). In a dev build it forces the real transports ON
# (emulator/device testing) AND tees observability to the console. Unset/false → dev
# stays console-only. Ignored in release builds (they always send).
EXPO_PUBLIC_DEBUG=

# --- Mobile (Expo) ---
# Overrides the API base URL the app calls. Unset → prod (https://whocards.cc) in
# release builds, the LAN host Expo reports in dev.
EXPO_PUBLIC_API_URL=

# --- App funnel visibility (optional; website) ---
# Per-store launch flags gate the public /app funnel. /app is visible (download
# mode) when either is true, and redirects home (no nav/homepage links) when both
# are false. iOS launches first; Android trails through its Closed Test.
#
# iOS App Store listing is public (default true — iOS is approved today).
PUBLIC_APP_IOS_LAUNCHED=true
# Google Play listing is public. Set 'true' once Google grants production access;
# until then the Android tile routes to /android-testers instead of a Play badge.
PUBLIC_APP_ANDROID_LAUNCHED=false

# --- Answer recording opt-in (optional) ---
# Recording feeds the shared Global progress and is ALWAYS on in production builds.
# In dev it is suppressed so local play doesn't pollute the real Answer record. Set
# to 'true' to opt in while developing. Two vars, same effect (platform env-prefix
# conventions): web → PUBLIC_RECORD_ANSWERS, mobile → EXPO_PUBLIC_RECORD_ANSWERS.
PUBLIC_RECORD_ANSWERS=
EXPO_PUBLIC_RECORD_ANSWERS=
