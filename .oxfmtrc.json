{
  "arrowParens": "always",
  "bracketSameLine": false,
  "bracketSpacing": false,
  "printWidth": 100,
  "semi": false,
  "singleQuote": true,
  "tabWidth": 2,
  "trailingComma": "es5",
  "useTabs": false,
  "sortPackageJson": false,
  "experimental": {
    "sortImports": true
  },
  "ignorePatterns": [
    "**/dist/**",
    "**/node_modules/**",
    "**/.astro/**",
    "**/.netlify/**",
    "**/.expo/**",
    "**/.turbo/**",
    "pnpm-lock.yaml",
    "**/drizzle/**",
    "apps/website/**"
  ]
}
