{
  "name": "whocards",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22",
    "pnpm": ">=10"
  },
  "packageManager": "pnpm@11.4.0",
  "scripts": {
    "build": "turbo build",
    "build:web": "turbo build --filter=website",
    "dev": "turbo dev",
    "dev:web": "turbo dev --filter=website",
    "dev:mobile": "pnpm --filter mobile start",
    "email:dev": "pnpm --filter @whocards/emails dev",
    "email:export": "pnpm --filter @whocards/emails export",
    "email:render": "pnpm --filter @whocards/emails render",
    "email:test-send": "pnpm --filter @whocards/emails test-send",
    "mobile:eas": "pnpm --filter mobile eas",
    "mobile:build:ios": "pnpm --filter mobile eas:build:ios",
    "mobile:build:android": "pnpm --filter mobile eas:build:android",
    "mobile:submit:ios": "pnpm --filter mobile eas:submit:ios",
    "mobile:submit:android": "pnpm --filter mobile eas:submit:android",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "test:e2e": "pnpm --filter website test:e2e",
    "test:e2e:ssr": "pnpm --filter website test:e2e:ssr",
    "db:generate": "pnpm --filter website db:generate",
    "db:migrate": "pnpm --filter website db:migrate",
    "db:push": "pnpm --filter website db:push",
    "db:studio": "pnpm --filter website db:studio",
    "lint": "oxlint --deny-warnings",
    "lint:fix": "oxlint --fix",
    "format": "oxfmt --check",
    "format:fix": "oxfmt",
    "check": "oxfmt --check && oxlint --deny-warnings && turbo typecheck test",
    "clean": "git clean -xdf node_modules",
    "clean:workspaces": "turbo run clean",
    "lint:ws": "pnpm dlx sherif@latest",
    "prepare": "husky"
  },
  "lint-staged": {
    "{packages,tooling,apps/mobile,apps/emails}/**/*.{ts,tsx,js,jsx,mjs,cjs}": [
      "oxlint --fix",
      "oxfmt --no-error-on-unmatched-pattern"
    ],
    "apps/website/**/*.{ts,tsx,js,jsx,mjs,cjs,astro}": [
      "pnpm --filter website exec prettier --write --plugin=prettier-plugin-astro"
    ],
    "*.{json,md,yaml,yml}": [
      "oxfmt --no-error-on-unmatched-pattern"
    ]
  },
  "devDependencies": {
    "dotenv-cli": "^11.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.0",
    "oxfmt": "^0.54.0",
    "oxlint": "^1.69.0",
    "turbo": "^2.6.3",
    "typescript": "catalog:"
  }
}
