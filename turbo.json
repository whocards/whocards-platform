{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "globalDependencies": [".env", "**/.env.*local", "tsconfig.json"],
  "envMode": "loose",
  "tasks": {
    "topo": {
      "dependsOn": ["^topo"]
    },
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", "!**/*.test.ts", "!**/*.test.tsx"],
      "outputs": ["dist/**", ".astro/**", "dist/_astro/**", ".netlify/**"]
    },
    "typecheck": {
      "dependsOn": ["^topo"],
      "outputs": []
    },
    "test": {
      "dependsOn": ["^topo"],
      "outputs": []
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "clean": {
      "cache": false
    }
  }
}
