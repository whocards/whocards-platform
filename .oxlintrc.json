{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["typescript", "import", "unicorn", "oxc", "node"],
  "categories": {
    "correctness": "error",
    "suspicious": "warn"
  },
  "rules": {
    "no-console": "error",
    "node/no-process-env": "error",
    "no-unused-vars": [
      "error",
      {"argsIgnorePattern": "^_", "varsIgnorePattern": "^_", "ignoreRestSiblings": true}
    ],
    "typescript/consistent-type-definitions": ["error", "type"],
    "typescript/consistent-type-imports": [
      "warn",
      {"prefer": "type-imports", "fixStyle": "separate-type-imports"}
    ],
    "typescript/no-non-null-assertion": "warn",
    "no-underscore-dangle": ["warn", {"allow": ["_attempts", "_u", "__dirname"]}],
    "import/no-default-export": "error",
    "import/consistent-type-specifier-style": ["error", "prefer-top-level"],
    "import/no-unassigned-import": ["error", {"allow": ["**/*.css", "server-only"]}]
  },
  "overrides": [
    {
      "files": [
        "**/scripts/**",
        "**/*.config.*",
        "**/*.test.ts",
        "**/*.test.tsx",
        "**/e2e/**",
        "**/e2e-ssr/**",
        "**/tests/**",
        "**/netlify/plugins/**"
      ],
      "rules": {
        "no-console": "off",
        "no-unsafe-finally": "off",
        "import/no-unassigned-import": "off",
        "node/no-process-env": "off",
        "typescript/no-non-null-assertion": "off"
      }
    },
    {
      "files": ["**/env.ts", "**/env.node.ts", "**/env.test.ts"],
      "rules": {
        "node/no-process-env": "off"
      }
    },
    {
      "files": ["**/jest.setup.*"],
      "rules": {
        "import/no-unassigned-import": "off"
      }
    },
    {
      "files": ["**/*.config.*"],
      "rules": {
        "import/no-default-export": "off"
      }
    },
    {
      "files": ["**/app/**/*.tsx", "**/app/**/*.ts", "**/pages/**/*.tsx", "**/pages/**/*.ts"],
      "rules": {
        "import/no-default-export": "off"
      }
    },
    {
      "files": ["**/*.d.ts"],
      "rules": {
        "typescript/triple-slash-reference": "off",
        "typescript/consistent-type-imports": "off",
        "typescript/consistent-type-definitions": "off"
      }
    }
  ],
  "ignorePatterns": [
    "**/dist/**",
    "**/node_modules/**",
    "**/.astro/**",
    "**/.netlify/**",
    "**/.expo/**",
    "**/.turbo/**",
    "**/drizzle/**"
  ]
}
