{
  "name": "website",
  "type": "module",
  "version": "1.4.1",
  "private": true,
  "scripts": {
    "with-env": "dotenv -e ../../.env${ENV:+.${ENV}} --",
    "dev": "pnpm with-env astro dev",
    "start": "pnpm with-env astro dev",
    "build": "pnpm with-env astro build",
    "preview": "pnpm with-env astro preview",
    "typecheck": "astro sync && astro check",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:ssr": "playwright test -c playwright.ssr.config.ts",
    "pretty": "prettier --write . --plugin=prettier-plugin-astro",
    "analyze": "pnpx unlighthouse --site https://whocards.cc",
    "db:generate": "pnpm with-env drizzle-kit generate",
    "db:migrate": "pnpm with-env drizzle-kit migrate",
    "db:push": "pnpm with-env drizzle-kit push",
    "db:studio": "pnpm with-env drizzle-kit studio",
    "reconcile:resend": "pnpm with-env tsx scripts/reconcile-resend.ts"
  },
  "dependencies": {
    "@whocards/api": "workspace:*",
    "@whocards/decks": "workspace:*",
    "@whocards/emails": "workspace:*",
    "@whocards/observability": "workspace:*",
    "@trpc/client": "catalog:",
    "@trpc/server": "catalog:",
    "@astrojs/mdx": "^5.0.6",
    "@astrojs/netlify": "^7.0.13",
    "@astrojs/react": "^5.0.7",
    "@astrojs/sitemap": "^3.7.3",
    "@iconify-icon/react": "^1.0.8",
    "@iconify-json/entypo-social": "^1.1.8",
    "@iconify-json/fa-solid": "^1.1.8",
    "@iconify-json/ic": "^1.1.17",
    "@iconify-json/mdi": "^1.1.64",
    "@iconify-json/ri": "^1.1.19",
    "@iconify-json/zondicons": "^1.1.8",
    "@nanostores/persistent": "^0.9.1",
    "@nanostores/react": "^0.7.1",
    "@pdf-lib/fontkit": "^1.1.1",
    "@resvg/resvg-js": "^2.6.2",
    "@t3-oss/env-core": "catalog:",
    "@tailwindcss/typography": "^0.5.20",
    "@tailwindcss/vite": "^4.3.1",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "astro": "^6.3.8",
    "astro-icon": "^1.1.5",
    "astro-robots-txt": "^1.0.0",
    "astro-seo": "^0.8.0",
    "bidi-js": "^1.0.3",
    "clsx": "^2.1.1",
    "daisyui": "^5.5.23",
    "drizzle-orm": "^0.33.0",
    "gsap": "^3.12.2",
    "nanostores": "^0.9.4",
    "object-to-formdata": "^4.5.1",
    "pdf-lib": "^1.17.1",
    "postgres": "^3.4.9",
    "posthog-js": "^1.393.4",
    "react": "catalog:",
    "react-dom": "catalog:",
    "resend": "^6.14.0",
    "satori": "^0.26.0",
    "sharp": "^0.34.5",
    "split-text-js": "^1.0.3",
    "svix": "^1.96.0",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.1",
    "wawoff2": "^2.0.1",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@astrojs/node": "^10.1.4",
    "@electric-sql/pglite": "^0.5.3",
    "@netlify/functions": "^2.3.0",
    "@playwright/test": "^1.61.1",
    "@types/node": "catalog:",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.24.2",
    "pg": "^8.11.3",
    "prettier": "^3.8.4",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
