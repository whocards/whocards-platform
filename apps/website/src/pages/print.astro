---
import Printer from '~components/Print'
import Layout from '~layouts/Layout.astro'
---

<Layout
  title='Print'
  description='Download WhoCards as a free, perfectly aligned PDF for your precut business-card sheets. Choose your language and sheet, then print and experience authentic connections.'
  showLangModal
  class='!justify-start'
>
  <section
    class='mx-auto flex w-full max-w-6xl flex-col gap-6 px-6 pt-8 pb-16 lg:gap-6 lg:pt-10 lg:pb-10'
  >
    <Printer client:load />
  </section>
</Layout>
