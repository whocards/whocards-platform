---
export const prerender = false

import {Icon} from 'astro-icon/components'
import {Resend} from 'resend'
import type {ZodIssue} from 'zod'
import {FormSuccess} from '~components/thanks'
import Button from '~components/ui/Button.astro'
import Input from '~components/ui/Input.astro'
import {contactLinks} from '~constants/navigation'
import {env} from '~env'
import {Layout} from '~layouts'
import {contactMessageSchema} from '~utils/schemas'

const siteKey = import.meta.env.PUBLIC_TURNSTILE_SITE_KEY as string | undefined

let formData: Record<string, string> | undefined
let errors: Record<string, ZodIssue> | undefined
let confirmed = false
let serverError: string | undefined

// Escape HTML to prevent injection in the email body.
function escapeHtml(str: string): string {
  return str
    .replace(/&/g, '&amp;')
    .replace(/</g, '&lt;')
    .replace(/>/g, '&gt;')
    .replace(/"/g, '&quot;')
    .replace(/'/g, '&#39;')
}

if (Astro.request.method === 'POST') {
  try {
    const rawFormData = await Astro.request.formData()
    formData = Object.fromEntries(rawFormData.entries()) as Record<string, string>

    // Verify Turnstile token when a secret key is configured.
    if (env.TURNSTILE_SECRET_KEY) {
      const token = formData['cf-turnstile-response'] ?? ''
      if (!token) {
        errors = {
          'cf-turnstile-response': {
            code: 'custom',
            message: 'Please complete the security check.',
            path: ['cf-turnstile-response'],
          } as ZodIssue,
        }
      } else {
        const verifyBody = new URLSearchParams({
          secret: env.TURNSTILE_SECRET_KEY,
          response: token,
        })
        const verifyRes = await fetch(
          'https://challenges.cloudflare.com/turnstile/v0/siteverify',
          {method: 'POST', body: verifyBody}
        )
        const verifyData = (await verifyRes.json()) as {success: boolean}
        if (!verifyData.success) {
          errors = {
            'cf-turnstile-response': {
              code: 'custom',
              message: 'Security check failed. Please try again.',
              path: ['cf-turnstile-response'],
            } as ZodIssue,
          }
        }
      }
    }

    if (!errors) {
      const parsed = contactMessageSchema.safeParse(formData)
      if (!parsed.success) {
        errors = Object.fromEntries(
          parsed.error.issues.map((issue) => [String(issue.path[0]), issue])
        )
      } else {
        const {name, email, message} = parsed.data

        if (!env.RESEND_API_KEY) {
          console.error('contact: RESEND_API_KEY not configured')
          serverError = 'Our contact system is temporarily unavailable. Please email us directly at hello@whocards.cc.'
        } else {
          const safeName = escapeHtml(name)
          const safeMessage = escapeHtml(message).replace(/\n/g, '<br>')

          const html = `
<div style="max-width:560px;margin:0 auto;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Helvetica,Arial,sans-serif;color:#1f1f1f;">
  <h2 style="font-size:20px;margin:0 0 16px;">New contact message from ${safeName}</h2>
  <table style="width:100%;border-collapse:collapse;margin-bottom:24px;">
    <tr>
      <td style="padding:8px 0;font-weight:600;width:80px;vertical-align:top;">Name</td>
      <td style="padding:8px 0;">${safeName}</td>
    </tr>
    <tr>
      <td style="padding:8px 0;font-weight:600;vertical-align:top;">Email</td>
      <td style="padding:8px 0;"><a href="mailto:${escapeHtml(email)}" style="color:#6c5ce7;">${escapeHtml(email)}</a></td>
    </tr>
  </table>
  <div style="background:#f5f5f5;border-radius:8px;padding:16px 20px;font-size:15px;line-height:1.6;">
    ${safeMessage}
  </div>
  <p style="font-size:12px;color:#888;margin-top:24px;">
    Sent via the WhoCards contact form at whocards.cc/contact
  </p>
</div>`

          const resend = new Resend(env.RESEND_API_KEY)
          const {error} = await resend.emails.send({
            from: env.RESEND_FROM_EMAIL,
            to: 'hello@whocards.cc',
            replyTo: email,
            subject: `Contact form: ${name}`,
            html,
          })

          if (error) {
            console.error('contact: resend error', error)
            serverError = "We couldn't send your message just now. Please try again or email us directly at hello@whocards.cc."
          } else {
            confirmed = true
          }
        }
      }
    }
  } catch (error) {
    console.error('contact: unexpected error', error)
    errors ??= {}
  }
}
---

<Layout title='Contact' description='Get in touch with the WhoCards team. We are here to help with app support, general questions, and anything else you need.' class='pt-28 lg:pt-32'>
  <div
    class='grid grid-flow-row md:grid-flow-col md:grid-cols-2 md:px-[2vw] lg:max-w-7xl px-5 xl:px-0 w-full justify-between items-start'
  >
    <div
      class='flex text-lg lg:text-xl text-gray-dark flex-col items-center md:items-start md:justify-start justify-center text-center md:text-start gap-4 md:gap-5 pb-14'
    >
      <h1
        class='text-3xl lg:text-5xl text-white md:pb-2 font-bold font-title tracking-tight leading-tight'
      >
        Contact Us
      </h1>
      <Icon name='chat' class='w-16 h-16' />
      <p class='md:text-lg font-semibold'>We would love to hear from you.</p>
      <p class='text-base'>
        Reach out for app support, general questions, or anything else — we read every message.
      </p>
      <Icon name='divider' class='w-64 py-2 md:hidden' />
      <Icon name='divider-left' class='w-3/4 py-4 hidden md:block' />
      <div class='grid grid-cols-2 lg:grid-cols-1 gap-3'>
        {
          contactLinks.map((link) => (
            <a
              href={link.href}
              target='_blank'
              class='flex items-center text-gray-dark hover:text-primary-light active:text-primary-dark gap-3'
            >
              <>
                <Icon name={link.icon as string} class='h-6 w-6' />
                <span class='block'>{link.title}</span>
              </>
            </a>
          ))
        }
      </div>
      <p class='text-sm text-gray-dark mt-2'>
        Looking to order WhoCards? <a href='/request-cards' class='underline text-primary-light hover:text-primary-dark'>Request cards here.</a>
      </p>
    </div>

    {
      confirmed ? (
        <FormSuccess
          class='h-full'
          type='message'
          href='/contact'
          title='Message sent!'
          message="Thanks for reaching out. We'll get back to you soon."
          buttonLabel='Send another message'
        />
      ) : (
        <div class='flex flex-col items-center text-center md:text-start md:items-start gap-4 md:gap-5'>
          <h2 class='text-3xl lg:text-5xl text-gradient font-bold font-title tracking-tight leading-tight'>
            Send us a message
          </h2>
          {serverError && (
            <p class='lg:text-base text-red-500'>{serverError}</p>
          )}
          {errors && !serverError && (
            <p class='lg:text-base text-red-500'>
              Please check the form and try again.
            </p>
          )}
          <form method='POST' class='flex flex-col w-full pb-14'>
            <Input
              name='name'
              min={2}
              autocomplete='name'
              required
              value={formData?.name ?? ''}
              error={errors?.name}
            />
            <Input
              name='email'
              type='email'
              autocomplete='email'
              required
              value={formData?.email ?? ''}
              error={errors?.email}
            />
            <label
              for='contact-message'
              class='text-start text-base font-medium flex flex-col gap-2 pb-2.5'
            >
              <div>message *</div>
              <textarea
                id='contact-message'
                name='message'
                rows={5}
                required
                minlength={10}
                maxlength={2000}
                class='w-full bg-transparent py-3 px-4.5 border placeholder:text-gray-dark rounded-xl'
                class:list={[errors?.message ? 'border-red' : 'border-gray']}
                placeholder='How can we help?'
                set:text={formData?.message ?? ''}
              />
              <p class='text-xs text-red'>{errors?.message?.message ?? <>&nbsp;</>}</p>
            </label>

            {siteKey ? (
              <div
                class='cf-turnstile mb-4'
                data-sitekey={siteKey}
                data-theme='dark'
              />
            ) : null}
            {errors?.['cf-turnstile-response'] && (
              <p class='text-xs text-red mb-4'>{errors['cf-turnstile-response'].message}</p>
            )}

            <Button type='submit' class='mt-4 capitalize lg:max-w-xs' full>
              Send message
            </Button>
          </form>
        </div>
      )
    }
  </div>
</Layout>

{siteKey && (
  <script
    is:inline
    src='https://challenges.cloudflare.com/turnstile/v0/api.js'
    async
    defer
  />
)}
