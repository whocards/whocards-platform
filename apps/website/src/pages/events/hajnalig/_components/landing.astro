---
import Button from '~components/ui/Button.astro'
import {editions} from '../_data/editions'
import type {EditionYear} from '../_data/editions'
import Footer from './footer.astro'

type Props = {
  year: EditionYear
}

const {year} = Astro.props
const edition = editions[year]
// Round interactions down to a clean "+" figure for display.
const moments = Math.floor(edition.stats.moments / 100) * 100
---

<div class='text-center space-y-4 md:space-y-8 w-full'>
  <h1 class='text-center font-title font-bold text-4xl md:text-7xl md:pb-8'>
    Koccints. Kérdezz.<br />Kapcsolódj!
  </h1>
  <p
    class='justify-self-center text-center text-sm md:text-lg font-semibold leading-4 md:leading-7 max-w-xl'
  >
    A kártya nálad van, és Te döntesz. Ha kíváncsi vagy kezdeményezz egy beszélgetést. A kérdéseket
    pedig értelmezd szabadon.
  </p>

  <!-- Per-edition engagement (snapshot — see _data/editions.ts) -->
  <p class='text-center text-xs md:text-sm font-semibold uppercase tracking-wide text-darkest/70'>
    Hajnalig {edition.year} · {edition.stats.people}+ résztvevő · {edition.stats.questions} kérdés · {
      moments.toLocaleString('hu-HU')
    }+ pillanat
  </p>

  <div
    class='grid grid-flow-row md:grid-flow-col md:grid-cols-2 gap-4 md:gap-8 w-full md:max-w-xl py-2.5 md:py-5 lg:pt-8 mx-auto'
  >
    <Button tag='a' class='play py-2' size='lg' full href={edition.playHref}>Új kérdés</Button>
    <Button
      tag='a'
      href='/request-cards'
      full
      hideIcon
      variant='secondary'
      class='py-2 hover:bg-primary-dark/20 active:bg-primary-dark/40'>Kérj kártyát</Button
    >
  </div>
  <Footer />
</div>
