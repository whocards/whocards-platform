---
import {getDirection} from '@whocards/decks/engine'

import Button from '~components/ui/Button.astro'
import WhoCard from '~components/ui/WhoCard.astro'
import languages from '~data/languages.json'
import questions from '~data/questions.json'
import Layout from '~layouts/Layout.astro'
import type {Language, QuestionId} from '~types'

// Restores the static `/[language]/question/[id]` pages (#45): they were removed
// at some point but stayed indexed by Google and are actively cited by ChatGPT —
// live traffic still lands on them from both, and 404s there burn SEO/AEO equity
// for no reason. Every (language, id) pair that has question text gets a static,
// prerendered page (~66 questions x up to 14 languages).
//
// Per-question <title>/<meta description> and Question/CreativeWork JSON-LD are
// generated by Head.astro (#46) from `Astro.params.id`/`Astro.params.language`,
// which this route supplies natively — no props needed (see the comment on
// Head.astro's `id`/`language` props for the SSR-page equivalent, /play).
export async function getStaticPaths() {
  return Object.entries(questions).flatMap(([id, translations]) =>
    Object.keys(translations)
      .filter((language) => language in languages)
      .map((language) => ({params: {language, id}}))
  )
}

const {language, id} = Astro.params as {language: Language; id: QuestionId}
const text = questions[id]?.[language]

// Defensive: getStaticPaths only emits pairs that have text, but guard anyway.
if (!text) {
  return Astro.redirect(`/play?lang=${language}`, 302)
}

// Questions are stored as "main line\n\n(parenthetical context)" — split so the
// heading reads as the question and the context renders underneath it.
const [main, ...rest] = text.split('\n\n')
const context = rest.join(' ').trim()
const direction = getDirection(language)
const playHref = `/play?lang=${language}&q=${id}`
---

<Layout lang={language}>
  <div
    class='flex flex-col items-center gap-8 px-6 py-16 max-w-2xl mx-auto text-center'
    dir={direction}
  >
    <h1
      class='font-title font-bold text-gradient text-3xl lg:text-5xl whitespace-pre-line leading-tight'
    >
      {main}
    </h1>
    {context && <p class='text-base lg:text-lg text-gray-lighter whitespace-pre-line'>{context}</p>}
    <WhoCard lang={language} id={id} class='mx-auto' />
    <Button tag='a' href={playHref} size='lg'>Play this question</Button>
    <a
      href='/'
      class='text-sm font-semibold text-gray-lighter underline-offset-4 transition-colors hover:text-primary-light hover:underline'
    >
      &larr; Back to WhoCards
    </a>
  </div>
</Layout>
