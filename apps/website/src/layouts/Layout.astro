---
import {LanguageSwitcher} from '~components/Modal/LanguageSwitcher'
import Navigation from '~components/Navigation.astro'
import PostHog from '~components/PostHog.astro'
import Head from './Head.astro'

import BackgroundImages from '~components/ui/BackgroundImages.astro'
import {APP_LAUNCHED, APP_STORE_APP_ID} from '~constants/app'
import {mainLinks, type Link} from '~constants/navigation'
import '~styles/base.css'
import Footer from './Footer.astro'

export interface Props {
  class?: string
  title?: string
  description?: string
  noindex?: boolean
  lang?: string
  showLangModal?: boolean
  links?: Link[]
  image?: string
  // question id for SSR pages (e.g. /play) that drive per-question metadata
  id?: string
  oldBg?: boolean
  noFooter?: boolean
}

const {
  class: mainClasses,
  title,
  description,
  noindex = false,
  lang = 'en',
  showLangModal = false,
  links = mainLinks,
  image,
  id,
  oldBg = false,
  noFooter = false,
} = Astro.props
---

<!doctype html>
<html lang={lang} class='scroll-smooth bg-darkest'>
  <head>
    <Head
      title={title}
      description={description}
      noindex={noindex}
      image={image}
      id={id}
      language={lang}
    />
    {/* iOS Smart App Banner — surfaces install/open on iOS Safari sitewide once launched (#90) */}
    {APP_LAUNCHED && <meta name='apple-itunes-app' content={`app-id=${APP_STORE_APP_ID}`} />}
    <PostHog />
  </head>
  <body
    class='m-0 flex min-h-screen flex-col font-sans text-white selection:bg-primary-dark selection:text-primary-light scrollbar-hide'
    class:list={[oldBg && 'bg-hero bg-fixed bg-center bg-no-repeat bg-cover']}
  >
    <Navigation links={links}>
      {
        !oldBg && (
          <span class='-z-10 overflow-hidden absolute top-0 right-0 left-0 bottom-0'>
            <BackgroundImages />
          </span>
        )
      }
      <main
        class='flex min-h-screen pt-16 w-full flex-col items-center justify-center'
        class:list={[mainClasses]}
      >
        <slot />
      </main>
      {!noFooter && <Footer />}
    </Navigation>
    {showLangModal && <LanguageSwitcher client:only />}
    <style is:global></style>
  </body>
</html>
