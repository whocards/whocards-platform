---
import {socialLinks} from '~constants/navigation'
import questions from '~data/questions.json'

// Short, templated per-language line appended after the question text in the
// meta description (#46) — the question text itself is what makes each of the
// ~900 (question x language) pages unique; this suffix just gives crawlers/AEO
// context. Keep translations short; they don't need to be perfect, just correct
// and on-brand.
const QUESTION_DESCRIPTION_SUFFIX: Record<string, string> = {
  en: 'a WhoCards conversation-starter question — play free online in 14 languages.',
  da: 'et WhoCards-samtalespørgsmål — spil gratis online på 14 sprog.',
  de: 'eine WhoCards-Gesprächsfrage — kostenlos online in 14 Sprachen spielen.',
  es: 'una pregunta de conversación de WhoCards — juega gratis online en 14 idiomas.',
  fr: 'une question de conversation WhoCards — jouez gratuitement en ligne en 14 langues.',
  he: 'שאלת שיחה של WhoCards — שחקו בחינם באינטרנט ב-14 שפות.',
  hu: 'egy WhoCards beszélgetésindító kérdés — játssz ingyen online 14 nyelven.',
  pl: 'pytanie konwersacyjne WhoCards — graj za darmo online w 14 językach.',
  pt: 'uma pergunta de conversa da WhoCards — joga grátis online em 14 idiomas.',
  'pt-br': 'uma pergunta de conversa do WhoCards — jogue grátis online em 14 idiomas.',
  ro: 'o întrebare de conversație WhoCards — joacă gratuit online în 14 limbi.',
  sr: 'WhoCards питање за разговор — играј бесплатно онлајн на 14 језика.',
  zh: 'WhoCards 對話破冰問題 — 免費線上遊玩，支援 14 種語言。',
  jp: 'WhoCardsの会話のきっかけになる質問 — 14言語で無料オンラインプレイ。',
}

const MAX_DESCRIPTION_LENGTH = 160

// Word-boundary truncation — never cut mid-word. Used only on the question
// text itself so the (short, fixed) per-language suffix always survives; see
// buildQuestionDescription.
const truncateAtWordBoundary = (text: string, max: number): string => {
  if (text.length <= max) return text
  const cut = text.slice(0, max)
  const lastSpace = cut.lastIndexOf(' ')
  return `${(lastSpace > 0 ? cut.slice(0, lastSpace) : cut).trimEnd()}…`
}

const buildQuestionDescription = (questionText: string, language?: string): string => {
  const suffix =
    (language && QUESTION_DESCRIPTION_SUFFIX[language]) || QUESTION_DESCRIPTION_SUFFIX.en
  // Reserve room for " — " + the suffix so long questions truncate instead of
  // pushing the suffix out of the description entirely.
  const budget = Math.max(0, MAX_DESCRIPTION_LENGTH - suffix.length - 3)
  return `${truncateAtWordBoundary(questionText, budget)} — ${suffix}`
}

export interface Props {
  title?: string
  description?: string
  image?: string
  noindex?: boolean
  // id/language let SSR pages (e.g. /play) supply the per-question metadata that
  // static question pages used to get from route params.
  id?: string
  language?: string
}

const fonts = ['aptly_regular', 'aptly_medium', 'golos_text']

const {id: paramId, language: paramLang} = Astro.params
const {
  title: propTitle,
  description: propDesc,
  image: img,
  noindex = false,
  id: propId,
  language: propLang,
} = Astro.props
const id = paramId ?? propId
const language = paramLang ?? propLang
const site = Astro.site

const canonicalUrl = new URL(Astro.url.pathname, site)

// non question pages
const titles: string[] = ['WhoCards']
let description =
  propDesc ||
  'WhoCards help us create conversations that encourage honest self-expression, active listening and deeper human connections.'
let image = img || `social.png`

if (propTitle) {
  titles.push(propTitle)
}

// question pages
// Question text (localized) drives unique title/description/JSON-LD per
// (id, language) pair (#46) instead of the old "Question #N" / "Dare to be
// Curious?" duplicate content. Hoisted above the `if` so the JSON-LD block
// below can also read it.
//
// `~data/questions.json` is the WhoCards library pool — it is NOT the source
// of question text for every id-bearing page. /play and /play/[deck] also
// pass an `id` (from ?q=), but that id is scoped to whichever deck is being
// played (e.g. the "hajnalig" deck has its own question #1, unrelated to
// library question #1) — see `~data/decks`. Looking the id up in the global
// pool there would silently show the wrong question's text. Only the
// restored `/[language]/question/[id]` static page's id is guaranteed to
// index the library pool, so gate the lookup on that route specifically.
const isQuestionPageRoute = /\/question\/[^/]+\/?$/.test(Astro.url.pathname)
const rawText =
  isQuestionPageRoute && id && language
    ? (questions as Record<string, Record<string, string>>)[id]?.[language]
    : undefined
// Split on the blank line questions.json uses to separate the main question
// from its parenthetical context — only the main line belongs in the title.
const mainLine = rawText?.split('\n\n')[0]?.replace(/\s+/g, ' ').trim()

if (id) {
  titles.push(mainLine || `Question #${id}`)
  // Card image is generated programmatically from questions.json at build time
  // (see src/pages/og/[language]/[id].png.ts) — no committed PNG required.
  if (!img) image = `og/${language}/${id}.png`
  description = mainLine ? buildQuestionDescription(mainLine, language) : 'Dare to be Curious?'
}
// complete image url
image = `${site}${site?.toString().endsWith('/') ? '' : '/'}` + image

const title = titles.join(' | ')
---

<!-- Global Metadata -->
<meta charset='utf-8' />
<meta name='viewport' content='width=device-width' />

<!-- Primary Meta Tags -->
<title>{title}</title>
<meta name='title' content={title} />
{description && <meta name='description' content={description} />}
{noindex && <meta name='robots' content='noindex, follow' />}
<link rel='canonical' href={canonicalUrl} />

<!-- Favicon -->
<link
  rel='icon'
  type='image/svg+xml'
  href='/favicons/favicon-light.svg'
  media='(prefers-color-scheme: light)'
/>
<link
  rel='icon'
  type='image/svg+xml'
  href='/favicons/favicon-dark.svg'
  media='(prefers-color-scheme: dark)'
/>
<link rel='apple-touch-icon' href='/apple-touch-icon.png' />
<link rel='icon' href='/favicon.ico' sizes='any' />

<!-- Open Graph -->
<meta property='og:type' content='website' />
<meta property='og:url' content={canonicalUrl} />
<meta property='og:title' content={title} />
<meta property='og:description' content={description} />
<meta property='og:image' content={image} />
<meta property='og:image:width' content='1200' />
<meta property='og:image:height' content='630' />
<meta property='og:locale' content={language} />

<!-- Twitter -->
<meta property='twitter:card' content='summary_large_image' />
<meta property='twitter:url' content={canonicalUrl} />
<meta property='twitter:title' content={title} />
<meta property='twitter:description' content={description} />
<meta property='twitter:image' content={image} />

<!-- generator -->
<meta name='generator' content={Astro.generator} />

<!-- fonts -->
{
  fonts.map((font) => (
    <link rel='preload' href={`/fonts/${font}.woff2`} as='font' type='font/woff2' crossorigin />
  ))
}

<!-- JSON-LD structured data -->
<script
  is:inline
  type='application/ld+json'
  set:html={JSON.stringify([
    {
      '@context': 'https://schema.org',
      '@type': 'Organization',
      name: 'WhoCards',
      url: site?.toString(),
      // Stable brand asset — `image` is the per-page OG image (a per-question card
      // on /play), which is not a valid Organization logo. social.png is the
      // canonical brand mark in /public.
      logo: `${site?.toString().replace(/\/$/, '')}/social.png`,
      // Source of truth for social URLs lives in ~constants/navigation.
      sameAs: socialLinks.map((link) => link.href),
    },
    {
      '@context': 'https://schema.org',
      '@type': 'WebSite',
      name: 'WhoCards',
      url: site?.toString(),
    },
    // Per-question structured data (#46). CreativeWork (not Question) — the
    // schema.org Question type expects an acceptedAnswer/answerCount for Q&A
    // rich results, which doesn't apply here (these are conversation-starter
    // prompts, not answered questions), so Question markup without an answer
    // would fail the Rich Results test. CreativeWork cleanly models "a short
    // piece of content, in this language, at this URL" instead.
    ...(id && mainLine
      ? [
          {
            '@context': 'https://schema.org',
            '@type': 'CreativeWork',
            '@id': canonicalUrl.toString(),
            name: mainLine,
            text: rawText,
            inLanguage: language,
            url: canonicalUrl.toString(),
            isPartOf: {'@type': 'WebSite', name: 'WhoCards', url: site?.toString()},
          },
        ]
      : []),
  ])}
/>
