# apps/website environment — copy to `.env` and fill in.
#   cp apps/website/.env.example apps/website/.env
# Validated by src/env-secrets.ts (t3-env). Server vars are secret; only PUBLIC_*
# are exposed to the client. Optional vars can be left blank/removed.

# --- Database (Postgres) — used by the app and the db:* scripts ---
DB_URL=postgres://user:password@localhost:5432/whocards

# --- Stripe (checkout + webhooks) ---
STRIPE_PRIVATE_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# JSON map of quantity -> { price, shipping } Stripe price ids:
STRIPE_PRODUCTS={"1":{"price":"price_...","shipping":"price_..."},"2":{"price":"price_...","shipping":"price_..."},"5":{"price":"price_...","shipping":"price_..."},"12":{"price":"price_...","shipping":"price_..."}}
PUBLIC_STRIPE_PUBLIC_KEY=pk_test_...

# --- Open Collective (donations / orders) ---
OC_API_KEY=
OC_API_URL=https://api.opencollective.com
OC_URL=https://opencollective.com/whocards
OC_PRODUCT_IDS=1,2,5,12
OC_REDIRECT_URL=                       # optional

# --- Zen (fulfilment) ---
ZEN_API_KEY=
ZEN_API_URL=

# --- Egon (shop / inventory) ---
EGON_AUTH_ID=
EGON_AUTH_KEY=
EGON_AUTH_TOKEN=
EGON_SHOP_ID=0
EGON_ITEM_ONE_ID=0
EGON_ITEM_ONE_PRICE=0
EGON_ITEM_TWELVE_ID=0
EGON_ITEM_TWELVE_PRICE=0

# --- Google Sheets webhooks (orders / shipping / contacts) ---
PURCHASE_SHEET_URL=
SHIPPING_SHEET_URL=
CONTACTS_SHEET_URL=

# --- Webhook auth (incoming) ---
WEBHOOK_AUTH_TOKEN=

# --- Resend (AI Check-In lead-magnet email) — optional ---
RESEND_API_KEY=                        # optional; route degrades gracefully without it
RESEND_FROM_EMAIL=WhoCards <hello@whocards.cc>   # must be a Resend-verified sender

# --- PostHog (analytics) — optional ---
PUBLIC_POSTHOG_KEY=                    # optional
PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com

# --- Runtime / deploy (optional locally) ---
# NODE_ENV / CONTEXT are read when present. SITE_URL is derived in
# src/constants/env.ts: it defaults to http://localhost:4321 locally and is set
# from Netlify's URL / DEPLOY_PRIME_URL (with CONTEXT) on deploy — no need to set
# those by hand in local dev.
