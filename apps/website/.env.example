# Copy to .env and fill in values. Never commit .env.

# Database
DB_URL=

# Google Sheets (contact exports)
CONTACTS_SHEET_URL=

# Resend — transactional email. All four values below are REQUIRED (build fails
# without them) so a misconfigured deploy fails loudly instead of silently dropping
# email or consent events.
RESEND_API_KEY=
RESEND_FROM_EMAIL=WhoCards <hello@whocards.cc>

# Resend Segment (Audience) ids for consent sync (#120).
# Find these in Resend → Contacts → Segments → copy the segment id.
RESEND_SEGMENT_NEWSLETTER_ID=
RESEND_SEGMENT_APP_WAITLIST_ID=

# Resend webhook signing secret for verifying Svix signatures (#121), format whsec_...
# Must match the endpoint's signing_secret: Resend → Webhooks → your endpoint,
# or GET https://api.resend.com/webhooks/{id}.
RESEND_WEBHOOK_SECRET=

# PostHog
PUBLIC_POSTHOG_KEY=
PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com
PUBLIC_POSTHOG_UI_HOST=https://eu.posthog.com

# App store launch flags. /app is visible (download mode) when either is true,
# and redirects home when both are false. iOS is public today; Android trails
# through its Closed Test, so its tile routes to /android-testers until flipped.
PUBLIC_APP_IOS_LAUNCHED=true
PUBLIC_APP_ANDROID_LAUNCHED=false
