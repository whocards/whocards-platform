{
  "expo": {
    "name": "WhoCards",
    "slug": "whocards-app",
    "version": "1.0.0",
    "orientation": "default",
    "icon": "./assets/images/icon.png",
    "scheme": "mobile",
    "userInterfaceStyle": "automatic",
    "runtimeVersion": {
      "policy": "fingerprint"
    },
    "updates": {
      "url": "https://u.expo.dev/70c97b4d-b05c-4839-a6a3-054bb0625e1f"
    },
    "ios": {
      "bundleIdentifier": "cc.whocards.mobile",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "cc.whocards.mobile",
      "blockedPermissions": [
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE"
      ],
      "adaptiveIcon": {
        "backgroundColor": "#08001A",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": true
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#08001a",
          "image": "./assets/images/logo.png",
          "imageWidth": 280,
          "resizeMode": "contain"
        }
      ],
      "expo-image",
      [
        "expo-font",
        {
          "fonts": [
            "./assets/fonts/golos-text.ttf",
            "./assets/fonts/aptly.ttf",
            "./assets/fonts/noto-sans-hebrew.ttf"
          ]
        }
      ],
      "expo-updates",
      "expo-localization"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": "70c97b4d-b05c-4839-a6a3-054bb0625e1f"
      }
    }
  }
}
