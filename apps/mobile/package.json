{
  "name": "mobile",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "with-env": "dotenv -e ../../.env${ENV:+.${ENV}} --",
    "start": "pnpm with-env expo start --dev-client",
    "android": "pnpm with-env expo start --dev-client --android",
    "ios": "pnpm with-env expo start --dev-client --ios",
    "web": "pnpm with-env expo start --web",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "oxlint --deny-warnings",
    "e2e": "maestro test .maestro --exclude-tags=screenshots",
    "screenshots": "bash scripts/capture-screenshots.sh",
    "eas": "pnpx eas-cli@latest",
    "eas:build:ios": "pnpx eas-cli@latest build -p ios --profile production",
    "eas:build:android": "pnpx eas-cli@latest build -p android --profile production",
    "eas:submit:ios": "pnpx eas-cli@latest submit -p ios --profile production --latest",
    "eas:submit:android": "pnpx eas-cli@latest submit -p android --profile production --latest"
  },
  "dependencies": {
    "@expo/metro-runtime": "~56.0.15",
    "@expo/vector-icons": "^15.1.1",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@trpc/client": "catalog:",
    "@trpc/server": "catalog:",
    "@whocards/api": "workspace:*",
    "@whocards/decks": "workspace:*",
    "@whocards/observability": "workspace:*",
    "@whocards/tokens": "workspace:*",
    "expo": "~56.0.12",
    "expo-application": "~56.0.3",
    "expo-dev-client": "~56.0.20",
    "expo-constants": "~56.0.18",
    "expo-crypto": "~56.0.4",
    "expo-device": "~56.0.4",
    "expo-file-system": "~56.0.8",
    "expo-font": "~56.0.7",
    "expo-haptics": "~56.0.3",
    "expo-image": "~56.0.11",
    "expo-linking": "~56.0.14",
    "expo-localization": "~56.0.6",
    "expo-router": "~56.2.11",
    "expo-splash-screen": "~56.0.10",
    "expo-store-review": "~56.0.3",
    "expo-status-bar": "~56.0.4",
    "expo-system-ui": "~56.0.5",
    "expo-updates": "~56.0.19",
    "nativewind": "^4.1.23",
    "posthog-react-native": "^4.50.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-css-interop": "0.2.5",
    "react-native-gesture-handler": "~2.31.1",
    "react-native-reanimated": "4.3.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.8.3",
    "tailwindcss": "^3.4.17",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@babel/plugin-transform-react-jsx": "^7.29.7",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^29.5.14",
    "@types/react": "~19.2.2",
    "babel-plugin-react-compiler": "1.0.0",
    "babel-preset-expo": "~56.0.15",
    "jest": "^29.7.0",
    "jest-expo": "~56.0.5",
    "typescript": "~6.0.3"
  }
}
