# apps/mobile environment — copy to `.env` and fill in (Expo inlines EXPO_PUBLIC_*).
#   cp apps/mobile/.env.example apps/mobile/.env

# Base URL of the WhoCards API (the apps/website tRPC mount). Optional: in dev the
# app falls back to the LAN host Expo reports on port 4321 (see src/lib/trpc.ts).
EXPO_PUBLIC_API_URL=http://localhost:4321
